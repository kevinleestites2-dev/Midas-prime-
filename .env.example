WORK_ALLOCATION_PCT=0.30
RESERVE_PCT=0.10

# Safety
MAX_DRAWDOWN_PCT=0.20
CIRCUIT_BREAKER_LOSSES=5

# Polymarket (optional)
POLY_API_KEY=
POLY_SECRET=
POLY_BASE=https://clob.polymarket.com

# Flywheel timing (seconds)
FLYWHEEL_INTERVAL=1800
META_REWRITE_INTERVAL=7200
