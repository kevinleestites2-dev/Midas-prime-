# MidasPrime Configuration

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama (local LLM)
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Capital Settings
INITIAL_CAPITAL=0.0
AUTO_WITHDRAW_THRESHOLD=500.0
AUTO_WITHDRAW_PCT=0.25

# Allocation (must sum to 1.0)
